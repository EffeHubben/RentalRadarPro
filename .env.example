# Copy this file to .env in the project root before running docker compose.
# Docker Compose reads this project-root .env file for build args and runtime env.

DATABASE_URL=sqlite:////data/rental_radar_pro.db
JWT_SECRET_KEY=replace-with-a-long-random-secret
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAMESITE=lax
AUTH_REFRESH_COOKIE_PATH=/api/auth
FRONTEND_ORIGIN=http://localhost:3000
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api
LISTING_SCAN_INTERVAL_MINUTES=5
LISTING_SOURCE_TIMEOUT_SECONDS=45
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=
BILLING_SUCCESS_URL=http://localhost:3000/account?checkout=success
BILLING_CANCEL_URL=http://localhost:3000/#pricing

# Payment provider switch: "stripe" (legacy) or "paddle" (active).
PAYMENT_PROVIDER=paddle
PADDLE_ENV=production
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET_KEY=
PADDLE_PRO_1M_PRICE_ID=
PADDLE_PRO_2M_PRICE_ID=
PADDLE_PRO_3M_PRICE_ID=
FRONTEND_URL=https://rentscout.nl
NEXT_PUBLIC_PAYMENT_PROVIDER=paddle
NEXT_PUBLIC_PADDLE_ENV=production
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
RESEND_API_KEY=
EMAIL_FROM=
APP_PUBLIC_URL=http://localhost:3000
EMAIL_VERIFICATION_ENABLED=false
EMAIL_VERIFICATION_TOKEN_EXPIRATION_MINUTES=4320
PASSWORD_RESET_ENABLED=true
PASSWORD_RESET_TOKEN_EXPIRATION_MINUTES=60
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TURNSTILE_REQUIRED=false

# Production example:
# REFRESH_COOKIE_SECURE=true
# AUTH_REFRESH_COOKIE_PATH=/api/auth
# FRONTEND_ORIGIN=https://rentscout.nl
# BACKEND_CORS_ORIGINS=https://rentscout.nl,https://www.rentscout.nl
# NEXT_PUBLIC_API_URL=https://api.rentscout.nl/api
# BILLING_SUCCESS_URL=https://rentscout.nl/account?checkout=success
# BILLING_CANCEL_URL=https://rentscout.nl/#pricing
